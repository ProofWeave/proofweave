# ============================================================
#  ProofWeave Environment Variables
#  비밀값은 macOS Keychain에서 런타임 로드 (config/keychain.ts)
# ============================================================

# ── Base Sepolia RPC ─────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── 컨트랙트 역할 주소 ──────────────────────────────────────
OWNER_ADDRESS=0x...      # 프로젝트 관리자 (업그레이드 권한)
OPERATOR_ADDRESS=0x...   # API 서버 지갑 (attest 권한)

# ── 배포된 Proxy 주소 ───────────────────────────────────────
PROXY_ADDRESS=0x...      # ERC1967Proxy 주소 (사용자 진입점)

# ── Basescan 검증 (선택) ────────────────────────────────────
BASESCAN_API_KEY=your_basescan_api_key

# ── API Server (Phase 2) ────────────────────────────────────
PINATA_GATEWAY=your_pinata_gateway
DATABASE_URL=postgresql://user:password@localhost:5432/proofweave

# ============================================================
#  Keychain 비밀값 (macOS 로컬 개발 전용)
#  아래 값들은 .env에 쓰지 않고 macOS Keychain에 등록합니다.
#  env.ts → keychain.ts가 런타임에 자동으로 읽어 process.env에 주입.
#  CI/Docker/프로덕션에서는 환경변수를 직접 설정하세요.
# ============================================================

# DEPLOYER_PRIVATE_KEY  — 배포자 프라이빗 키 (0x...)
# PINATA_JWT            — Pinata IPFS JWT 토큰
# CDP_API_KEY_ID        — CDP Portal → API Keys → Key ID
# CDP_API_KEY_SECRET    — CDP Portal → API Keys → Key Secret (Ed25519)
# CDP_WALLET_SECRET     — CDP Portal → Server Wallet → Generate Wallet Secret
# RECEIPT_SECRET        — HMAC 시크릿 (openssl rand -hex 32 으로 생성)

# ============================================================
#  Keychain 관리 명령어
# ============================================================
#
# 등록:
#   security add-generic-password -s SERVICE_NAME -a proofweave -w "값"
#
# 조회:
#   security find-generic-password -s SERVICE_NAME -a proofweave -w
#
# 삭제:
#   security delete-generic-password -s SERVICE_NAME -a proofweave
#
# 전체 등록 예시:
#   security add-generic-password -s DEPLOYER_PRIVATE_KEY -a proofweave -w "0x..."
#   security add-generic-password -s PINATA_JWT -a proofweave -w "eyJ..."
#   security add-generic-password -s CDP_API_KEY_ID -a proofweave -w "fe78..."
#   security add-generic-password -s CDP_API_KEY_SECRET -a proofweave -w "xaDq..."
#   security add-generic-password -s CDP_WALLET_SECRET -a proofweave -w "MIGH..."
#   security add-generic-password -s RECEIPT_SECRET -a proofweave -w "$(openssl rand -hex 32)"
