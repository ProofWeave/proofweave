# ============================================================
#  ProofWeave Environment Variables (로컬 개발용)
#  프로덕션: GCP Secret Manager + Vercel Environment Variables
#  비밀값: macOS Keychain에서 런타임 로드 (account: proofweave)
# ============================================================

# ── Base Sepolia RPC ─────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── 컨트랙트 역할 주소 (공개값) ──────────────────────────────
OWNER_ADDRESS=0x0df5Ea611e4868A42D600Aa2F552f72d7612f53c
OPERATOR_ADDRESS=0x0df5Ea611e4868A42D600Aa2F552f72d7612f53c

# ── IPFS (공개값) ────────────────────────────────────────────
PINATA_GATEWAY=your_pinata_gateway

# ── DB: Supabase Session Pooler (비밀) ───────────────────────
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres

# ── Supabase Auth (공개값 + 비밀값) ──────────────────────────
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Gemini (비밀) ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── 프론트엔드용 (Vite는 VITE_ prefix만 읽음, 공개 안전) ────
VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_API_URL=http://localhost:3001

# ── 비밀값: Keychain → .env 직접 입력 ────────────────────────
# Keychain에 있으면 자동 로드. 없으면 여기에 직접 입력.
# DEPLOYER_PRIVATE_KEY=0x...
# PINATA_JWT=eyJ...
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# CDP_WALLET_SECRET=
# RECEIPT_SECRET=
# DATA_ENCRYPTION_KEY=

# ── Basescan (선택) ──────────────────────────────────────────
# BASESCAN_API_KEY=your_basescan_key
